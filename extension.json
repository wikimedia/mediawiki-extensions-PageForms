	"type": "specialpage",
	"namespaces": [
		{
			"id": 106,
			"constant": "PF_NS_FORM",
			"name": "Form",
			"conditional": true
		},
		{
			"id": 107,
			"constant": "PF_NS_FORM_TALK",
			"name": "Form_talk",
			"conditional": true
		}
	],
	"callback": "PFHooks::registerExtension",
	"ExtensionFunctions": [
		"PFHooks::initialize"
	],
	"requires": {
