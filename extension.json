	},
	"GroupPermissions": {
		"*": {
			"viewedittab": true
		},
		"sysop": {
			"editrestrictedfields": true
		},
		"user": {
			"createclass": true,
			"multipageedit": true
		}
	},
	"AvailableRights": [
		"viewedittab",
		"editrestrictedfields",
		"createclass",
		"multipageedit"
	],
